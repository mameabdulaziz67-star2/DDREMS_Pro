# Railway will auto-provide DATABASE_URL when you add PostgreSQL plugin
# You only need to set these manually if NOT using Railway PostgreSQL plugin:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret — change this to a strong random string
JWT_SECRET=your_strong_secret_key_here

# Node environment
NODE_ENV=production

# Port — Railway sets this automatically, don't change
PORT=5000

# Frontend URL (your Railway frontend deployment URL)
FRONTEND_URL=https://your-app.up.railway.app

# Email Configuration for Password Reset
# Option 1: Gmail (requires App Password)
# Option 2: Mailtrap (free testing service)
# Option 3: Any SMTP service

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=namebicha@gmail.com
EMAIL_PASSWORD=kgmy eqsb zjyn eold


# Gmail App Password Instructions:
# 1. Go to https://myaccount.google.com/
# 2. Click "Security" in the left menu
# 3. Enable "2-Step Verification" if not already enabled
# 4. Go back to Security and look for "App passwords"
# 5. Select "Mail" and "Other (custom name)" - type "DDREMS"
# 6. Google will generate a 16-character password
# 7. Use that password in EMAIL_PASSWORD above

# Alternative: Use Mailtrap (free for testing)
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_SECURE=false
# EMAIL_USER=your-mailtrap-username
# EMAIL_PASSWORD=your-mailtrap-password
